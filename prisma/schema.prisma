generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  skills   String

  team_members TeamMember[]
  teams_led    Team[]       @relation("TeamLead")

  created_at DateTime @default(now())
}

model Team {
  id          String @id @default(uuid())
  name        String
  invite_code String @unique
  lead_id     String

  lead         User         @relation("TeamLead", fields: [lead_id], references: [id])
  team_members TeamMember[]
  tasks        Task[]
  meetings     Meeting[]
  messages     Message[]

  created_at DateTime @default(now())

  @@unique([name, lead_id])
}

model TeamMember {
  id      String @id @default(uuid())
  user_id String
  team_id String
  role    Role   @default(MEMBER)

  user User @relation(fields: [user_id], references: [id])
  team Team @relation(fields: [team_id], references: [id])

  assigned_tasks   Task[]    @relation("TaskAssignedTo")
  created_tasks    Task[]    @relation("TaskCreatedBy")
  created_meetings Meeting[] @relation("MeetingCreatedBy")

  created_at          DateTime             @default(now())
  meetingParticipants MeetingParticipant[] @relation("TeamMemberParticipants")
  messageSender       Message[]            @relation("MessageSender")

  @@unique([user_id, team_id])
}

enum Role {
  ADMIN
  MEMBER
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  deadline    DateTime?

  team_id String
  team    Team   @relation(fields: [team_id], references: [id])

  assigned_to_id String
  assigned_to    TeamMember @relation("TaskAssignedTo", fields: [assigned_to_id], references: [id])

  created_by_id String
  created_by    TeamMember @relation("TaskCreatedBy", fields: [created_by_id], references: [id])

  created_at DateTime @default(now())
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Meeting {
  id     String @id @default(uuid())
  title  String
  agenda String

  team_id String
  team    Team   @relation(fields: [team_id], references: [id])

  created_by_id String
  created_by    TeamMember @relation("MeetingCreatedBy", fields: [created_by_id], references: [id])

  start_time DateTime
  end_time   DateTime

  status MeetingStatus @default(SCHEDULED)

  participants MeetingParticipant[] @relation("MeetingParticipants")

  transcript String?
  summary    Json?

  created_at DateTime @default(now())
}

model MeetingParticipant {
  id             String @id @default(uuid())
  meeting_id     String
  team_member_id String

  meeting     Meeting    @relation("MeetingParticipants", fields: [meeting_id], references: [id])
  team_member TeamMember @relation("TeamMemberParticipants", fields: [team_member_id], references: [id])

  created_at DateTime @default(now())

  @@unique([meeting_id, team_member_id])
}

enum MeetingStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

model Message {
  id      String @id @default(uuid())
  content String

  sender_member_id String
  sender_member    TeamMember @relation("MessageSender", fields: [sender_member_id], references: [id])

  team_id String
  team    Team   @relation(fields: [team_id], references: [id])

  type MessageType @default(TEXT)

  created_at DateTime @default(now())
}

enum MessageType {
  TEXT
  COMMAND
}
